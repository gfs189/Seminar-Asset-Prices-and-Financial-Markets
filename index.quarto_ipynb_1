   "source": [
    "#| label: compute-beta\n",
    "#| echo: false\n",
    "#| output: false\n",
    "beta_ts = (\n",
    "    corr_component\n",
    "    .merge(vol_ratio, on=[\"permno\", \"month\"], how=\"inner\")\n",
    "    .assign(beta_ts=lambda x: (x[\"rho\"] * x[\"vol_ratio\"]).clip(lower=0.001))\n",
    "    [[\"permno\", \"month\", \"beta_ts\"]]\n",
    ")\n",
    "\n",
    "beta_estimates = beta_ts.assign(beta=lambda x: 0.6 * x[\"beta_ts\"] + 0.4)[[\"permno\", \"month\", \"beta\"]]"
   ]
