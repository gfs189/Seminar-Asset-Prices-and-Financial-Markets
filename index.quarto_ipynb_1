   "source": [
    "#| eval: false\n",
    "# Lagged market cap (one month) for portfolio weighting — computed from raw download\n",
    "mktcap_lag = (\n",
    "    crsp_monthly\n",
    "    .assign(\n",
    "        mktcap=lambda x: (x[\"shrout\"] * x[\"altprc\"].abs() / 1_000_000).replace(0, np.nan),\n",
    "        date=lambda x: x[\"date\"] + pd.DateOffset(months=1)\n",
    "    )\n",
    "    .rename(columns={\"mktcap\": \"mktcap_lag\"})\n",
    "    [[\"permno\", \"date\", \"mktcap_lag\"]]\n",
