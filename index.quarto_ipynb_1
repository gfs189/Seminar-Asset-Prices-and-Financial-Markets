    "#| label: compute-volatility\n",
    "#| echo: false\n",
    "#| output: false\n",
    "daily_vol = (\n",
    "    crsp_daily\n",
    "    .merge(factors_ff3_daily[[\"date\", \"mkt_excess\"]], on=\"date\", how=\"left\")\n",
