    "def rank_weights(betas):\n",
    "    \"\"\"Rank-based portfolio weights (Frazzini-Pedersen eq. 9).\"\"\"\n",
    "    k = betas.rank()\n",
    "    k = k - k.mean()\n",
    "    return k / k.abs().sum()\n",
    "\n",
    "def bab_month(df):\n",
    "    median_beta = df[\"beta\"].median()\n",
